@model Contracts.Responses.ViewRecipeResponse

@{
    ViewData["Title"] = Model.Content.Recipe.Title;
}
@section Styles
{
    <link rel="stylesheet" href="~/css/pages/recipe.css" />
}

<form action="/edit/@Model.Content.Recipe.Id">
    <input type="submit" value="Edit recipe" />
</form>

<div class="recipe-container">
    
    <!-- Overview -->
    <div class="overview-container">
        <div class="summary-container">
            <h1>@Model.Content.Recipe.Title</h1>
            <div class="timestamp-container">
                <p class="createdAtTime">Created: @Model.Content.Recipe.CreatedAt.ToString("yyyy MMMM dd kl.HH:mm")</p>
                <p class="updatedAtTime">Updated: @Model.Content.Recipe.UpdatedAt.ToString("yyyy MMMM dd kl.HH:mm")</p>
            </div>
            <div class="tag-container">
                @foreach (var tag in Model.Content.Recipe.RecipeTags)
                {
                    <span class="tag">@tag.Tag.Name</span>
                }
            </div>
                <div class="meta-container">
                    <!-- Rating here maybe -->
                    @{
                        int? hours = Model.Content.Recipe.TimeMinutes / 60;
                        int? minutes = Model.Content.Recipe.TimeMinutes - (hours * 60);
                    }
                    @if (hours > 0)
                    {
                        <span>⏱️ @hours h @minutes min</span>
                    }
                    else
                    {
                        <span>⏱️ @minutes min</span>
                    }
                    <span>🍽️ @Model.Content.Recipe.Portions portions</span>
                </div>
                <p>@Model.Content.Recipe.Description</p>
            <div class="source-container">
                @if (!string.IsNullOrEmpty(Model.Content.Recipe.Source)) // Is this even necessary? If no text, no div (essentially)
                {
                    if (!string.IsNullOrEmpty(Model.Content.Recipe.SourceUrl))
                    {
                        <p>Source: <a href="@Model.Content.Recipe.SourceUrl" target="_blank">@Model.Content.Recipe.Source</a></p>
                    }
                    else
                    {
                        <p>@Model.Content.Recipe.Source</p>
                    }
                }
            </div>
        </div>
        
        <div class="image-container">
            @{
                var mainImage = Model.Content.Recipe.Images.FirstOrDefault(i => i.IsMain);
            }
            @if (mainImage != null)
            {
                <img src="@mainImage.Path" alt="@Model.Content.Recipe.Title"/>
            }
            else
            {
                <div>@Model.Content.Recipe.Title</div>
            }
        </div>
    </div>
    
    <!-- Middle -->
    <div class="main-container">
        
        <div class="ingredients-container">
            <h2>Ingredients</h2>
            <ul>
            @foreach (var ingredient in Model.Content.Recipe.Ingredients)
                {
                    <li class="ingredient">
                        <input type="checkbox">
                        <label>
                            @if (ingredient.Amount != 0)
                            {
                                @($"{ingredient.Amount} ")
                            }
                            @($"{ingredient.Unit} {ingredient.Name}")
                        </label>
                    </li>
                }
            </ul>
        </div>
        
        <div class="instructions-container">
            <h2>Instructions</h2>
            <div class="instructions" style="display: block">
                @Html.Raw(Model.Content.InstructionsHtml) <!-- Render block wise? -->
            </div>
        </div>
    </div>

    <!-- Bottom/Other -->
    @if (!string.IsNullOrWhiteSpace(Model.Content.Recipe.Nutrition))
    {
        <div class="nutrition">
            <h2>Nutrition</h2>
            <p>@Model.Content.Recipe.Nutrition</p>
        </div>
    }
</div>